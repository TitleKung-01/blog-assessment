# PostgreSQL — ใช้ prisma dev หรือ connection string ของคุณเอง
DATABASE_URL="postgresql://USER:PASSWORD@127.0.0.1:5432/blog_assessment"

# (optional) สำหรับ seed / Prisma Studio เมื่อ DATABASE_URL เป็น prisma+postgres://
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@127.0.0.1:5432/blog_assessment"

# คีย์ลงนาม session cookie (อย่างน้อย 32 ตัวอักษร)
AUTH_SECRET="change-me-to-a-long-random-secret"

# รหัสสำหรับสมัครบัญชี ADMIN (ใช้ตอน POST /api/auth/sign-up role=ADMIN)
ADMIN_SIGNUP_CODE="your-admin-signup-code"
